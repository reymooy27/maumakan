// Prisma schema for Maumakan
// Column names in DB are camelCase (quoted), matching Prisma field names exactly.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Place {
  id        String       @id @default(uuid())
  name      String
  type      PlaceType
  address   String?
  lat       Float
  lng       Float
  rating    Float        @default(0)
  avgPrice  Int          @default(0)
  openTime  Int          @default(480)
  closeTime Int          @default(1320)
  imageUrl  String?
  createdAt DateTime     @default(now())
  menuItems MenuItem[]
  reviews      Review[]
  savedBy      SavedPlace[]
  photos       Photo[]
  checkIns     CheckIn[]
  crowdReports CrowdReport[]
  amenities    String[]
  ownerId      String?      @map("owner_id")
  owner        User?        @relation("ownedPlaces", fields: [ownerId], references: [id], onDelete: SetNull)

  @@map("places")
}

// ----------------------------------------------------------------------------
// NextAuth Models Core
// ----------------------------------------------------------------------------

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String?      @unique
  emailVerified DateTime?    @map("email_verified")
  image         String?
  accounts      Account[]
  sessions      Session[]
  savedPlaces   SavedPlace[]
  reviews       Review[]
  photos        Photo[]
  checkIns      CheckIn[]
  crowdReports  CrowdReport[]
  ownedPlaces   Place[]      @relation("ownedPlaces")

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

// ----------------------------------------------------------------------------
// Maumakan Personalized Models
// ----------------------------------------------------------------------------

model SavedPlace {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  placeId   String   @map("place_id")
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([userId, placeId])
  @@map("saved_places")
}

model MenuItem {
  id          String  @id @default(uuid())
  placeId     String
  place       Place   @relation(fields: [placeId], references: [id], onDelete: Cascade)
  name        String
  price       Decimal @db.Decimal(10, 2)
  description String?
  imageUrl    String?
  dietaryTags String[]
  photos      Photo[]

  @@map("menu_items")
}

model Review {
  id        String   @id @default(uuid())
  placeId   String
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  photos    Photo[]

  @@map("reviews")
}

enum PlaceType {
  restaurant
  cafe
  food_stall
}

// ----------------------------------------------------------------------------
// Phase 3: Photos & Social Context
// ----------------------------------------------------------------------------

model Photo {
  id          String   @id @default(uuid())
  url         String
  caption     String?
  createdAt   DateTime @default(now())
  
  userId      String?  @map("user_id")
  placeId     String?  @map("place_id")
  menuItemId  String?  @map("menu_item_id")
  reviewId    String?  @map("review_id")

  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  place     Place?     @relation(fields: [placeId], references: [id], onDelete: Cascade)
  menuItem  MenuItem?  @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  review    Review?    @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@map("photos")
}

model CheckIn {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  placeId   String   @map("place_id")
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@map("check_ins")
}

model CrowdReport {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  placeId   String   @map("place_id")
  status    String   // e.g "Busy", "Quiet", "Normal"
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@map("crowd_reports")
}
