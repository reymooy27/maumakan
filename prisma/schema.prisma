// Prisma schema for Maumakan
// Column names in DB are camelCase (quoted), matching Prisma field names exactly.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"

}

model Place {
  id         String     @id @default(uuid())
  name       String
  type       PlaceType
  address    String?
  lat        Float
  lng        Float
  rating     Float      @default(0)
  avgPrice   Int        @default(0)
  openTime   Int        @default(480)
  closeTime  Int        @default(1320)
  imageUrl   String?
  createdAt  DateTime   @default(now())
  menuItems  MenuItem[]
  reviews    Review[]

  @@map("places")
}

model MenuItem {
  id          String   @id @default(uuid())
  placeId     String
  place       Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  name        String
  price       Decimal  @db.Decimal(10, 2)
  description String?
  imageUrl    String?

  @@map("menu_items")
}

model Review {
  id        String   @id @default(uuid())
  placeId   String
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  userId    String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  @@map("reviews")
}

enum PlaceType {
  restaurant
  cafe
  food_stall
}
